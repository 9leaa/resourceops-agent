RESOURCEOPS_TRACE_DB=var/resourceops.sqlite3
RESOURCEOPS_APPROVAL_STORE=var/approvals.jsonl
RESOURCEOPS_AGENT_MODE=deterministic

# ResourceOps LLM config
# Local ccswitch / one-api / litellm / OpenAI-compatible servers can use these settings.
RESOURCEOPS_LLM_BASE_URL=http://127.0.0.1:3000/v1
RESOURCEOPS_LLM_API_KEY=replace-with-your-key
RESOURCEOPS_LLM_MODEL=replace-with-your-model
RESOURCEOPS_LLM_TIMEOUT_SECONDS=20
RESOURCEOPS_LLM_TEMPERATURE=0.2
# Optional provider-specific latency tier. Omit it when the provider does not support it.
RESOURCEOPS_LLM_SERVICE_TIER=fast
# Bound output length to keep planner/report calls below upstream gateway timeouts.
RESOURCEOPS_LLM_PLANNER_MAX_TOKENS=512
RESOURCEOPS_LLM_REPORT_MAX_TOKENS=640
RESOURCEOPS_LLM_MAX_RETRIES=1
RESOURCEOPS_LLM_RETRY_BACKOFF_SECONDS=1.0
# Store redacted full prompts/responses in raw/llm_calls.jsonl. Disabled by default.
RESOURCEOPS_STORE_LLM_PAYLOADS=false
